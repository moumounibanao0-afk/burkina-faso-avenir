<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Goulmou - Burkina Terres d'Avenir</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Source+Sans+3:wght@300;400;600&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Source Sans 3', sans-serif; }
    h1,h2,h3 { font-family: 'Playfair Display', serif; }
    .flag-stripe { height:6px; background: linear-gradient(90deg,#EF2B2D 50%,#009A00 50%); }
    .hero-goulmou {
      background-image:
        linear-gradient(to bottom, rgba(0,0,0,0.35), rgba(0,0,0,0.75)),
        url('data:image/jpeg;base64,');
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
    }
    .img-card { position:relative; overflow:hidden; border-radius:16px; }
    .img-card img { width:100%; height:240px; object-fit:cover; transition:transform 0.6s ease; display:block; }
    .img-card:hover img { transform:scale(1.07); }
    .overlay { position:absolute; inset:0; background:linear-gradient(to top,rgba(0,0,0,0.7) 0%,transparent 55%); }
    .caption { position:absolute; bottom:0; left:0; right:0; padding:16px; color:white; }
    .info-card { transition:all 0.35s ease; border-left:5px solid #E8B923; }
    .info-card:hover { transform:translateY(-5px); box-shadow:0 20px 40px rgba(232,185,35,0.15); }
    .prog-bar { height:10px; border-radius:999px; background:#e5e7eb; overflow:hidden; }
    .prog-fill { height:100%; border-radius:999px; background:linear-gradient(90deg,#E8B923,#008751); width:0; transition:width 1.6s ease; }
    .people-img { width:100%; height:200px; object-fit:cover; display:block; }
    .site-img { width:100%; height:200px; object-fit:cover; display:block; }
  </style>
</head>
<body class="bg-[#F5F0E8]">

  <div class="flag-stripe fixed top-0 w-full z-[60]"></div>

  <!-- NAVBAR -->
  <nav class="bg-white shadow-md fixed w-full z-50 top-[6px]">
    <div class="max-w-7xl mx-auto px-6 py-3 flex justify-between items-center">
      <a href="../index.html" class="flex items-center gap-3">
        <span class="text-2xl w-10 h-7 rounded flex items-center justify-center shadow-sm bg-white">🇧🇫</span>
        <div>
          <p class="text-lg font-bold text-[#008751] leading-tight" style="font-family:'Playfair Display',serif">Burkina Terres d'Avenir</p>
          <p class="text-xs text-gray-400 leading-tight">Valoriser nos 17 Régions</p>
        </div>
      </a>
      <div class="hidden md:flex gap-6 text-sm font-semibold">
        <a href="../index.html"      class="text-gray-600 hover:text-[#008751] transition">Accueil</a>
        <a href="../regions.html"    class="text-[#008751] border-b-2 border-[#008751]">Les 17 Régions</a>
        <a href="../potentiels.html" class="text-gray-600 hover:text-[#008751] transition">Potentiels</a>
        <a href="../culture.html"    class="text-gray-600 hover:text-[#008751] transition">Culture</a>
      </div>
      <a href="../regions.html" class="flex items-center gap-2 text-[#008751] font-bold text-sm hover:underline">← Toutes les régions</a>
    </div>
  </nav>

  <!-- HERO -->
  <header class="hero-goulmou min-h-[80vh] flex items-end text-white pt-24 pb-16 px-6">
    <div class="max-w-5xl mx-auto w-full">
      <span class="inline-block text-gray-800 text-xs font-bold px-4 py-1 rounded-full mb-4 uppercase tracking-widest" style="background:#E8B923">Zone Est</span>
      <h1 class="text-6xl md:text-8xl font-black mb-3">Goulmou</h1>
      <p class="text-2xl text-[#E8B923] font-bold mb-4">Chef-lieu : Fada N'Gourma</p>
      <p class="text-lg text-gray-200 max-w-2xl">Porte d'entrée de l'Est du Burkina Faso. Terre des Gourmantché, grande région d'élevage, de coton et de culture traditionnelle. Hospitalité légendaire.</p>
      <div class="flex flex-wrap gap-4 mt-8">
        <span class="bg-white/20 backdrop-blur px-4 py-2 rounded-full text-sm font-semibold">🐄 Élevage — Marché de bétail</span>
        <span class="bg-white/20 backdrop-blur px-4 py-2 rounded-full text-sm font-semibold">🌾 Coton &amp; Céréales</span>
        <span class="bg-white/20 backdrop-blur px-4 py-2 rounded-full text-sm font-semibold">🎭 Culture Gourmantché</span>
      </div>
    </div>
  </header>

  <!-- CHIFFRES CLÉS -->
  <section class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      <div><p class="text-4xl font-black text-[#E8B923]" style="font-family:'Playfair Display',serif">5</p><p class="text-gray-500 text-sm mt-1">Provinces</p></div>
      <div><p class="text-4xl font-black text-[#008751]" style="font-family:'Playfair Display',serif">Sirba</p><p class="text-gray-500 text-sm mt-1">Rivière principale</p></div>
      <div><p class="text-4xl font-black text-[#A0522D]" style="font-family:'Playfair Display',serif">Fada</p><p class="text-gray-500 text-sm mt-1">4ème ville du Burkina</p></div>
      <div><p class="text-4xl font-black text-[#EF2B2D]" style="font-family:'Playfair Display',serif">~800</p><p class="text-gray-500 text-sm mt-1">mm de pluie/an</p></div>
    </div>
  </section>

  <!-- PRÉSENTATION -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-[#E8B923] uppercase tracking-widest text-xs font-semibold mb-3">Présentation générale</p>
          <h2 class="text-4xl font-bold mb-6">Fada N'Gourma — Porte de l'Est</h2>
          <p class="text-gray-600 leading-relaxed mb-5">La région du <strong>Goulmou</strong> (Est) est la plus grande région du Burkina Faso en superficie. Elle est le fief du peuple <strong>Gourmantché</strong>, connu pour son hospitalité légendaire, sa culture vivante et son courage historique.</p>
          <p class="text-gray-600 leading-relaxed mb-5"><strong>Fada N'Gourma</strong>, son chef-lieu, est la quatrième ville du Burkina. Carrefour commercial important, elle est le point de départ vers les parcs nationaux de l'Est (Arly, W) et la frontière avec le Togo et le Bénin.</p>
          <p class="text-gray-600 leading-relaxed">La région est traversée par plusieurs cours d'eau — la <strong>Sirba</strong>, la <strong>Kompienga</strong> — et abrite le <strong>barrage de Kompienga</strong>, l'un des plus grands du Burkina, qui produit de l'électricité pour tout le pays.</p>
        </div>
        <div class="space-y-4">
          <div class="img-card shadow-xl">
            <img src="data:image/jpeg;base64," alt="Éléphants — Parc de l'Est Goulmou">
            <div class="overlay"></div>
            <div class="caption">
              <p class="font-bold">Faune sauvage — Goulmou</p>
              <p class="text-sm opacity-75">Porte d'entrée des parcs naturels de l'Est</p>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3 text-sm">
            <div class="bg-white rounded-xl p-4 shadow info-card"><p class="text-gray-400 text-xs mb-1">Superficie</p><p class="font-bold text-lg">~46 256 km²</p></div>
            <div class="bg-white rounded-xl p-4 shadow info-card"><p class="text-gray-400 text-xs mb-1">Pluviométrie</p><p class="font-bold text-lg">~800 mm/an</p></div>
            <div class="bg-white rounded-xl p-4 shadow info-card"><p class="text-gray-400 text-xs mb-1">Barrage</p><p class="font-bold text-lg">Kompienga 14MW</p></div>
            <div class="bg-white rounded-xl p-4 shadow info-card"><p class="text-gray-400 text-xs mb-1">Langue locale</p><p class="font-bold text-lg">Gourmanchéma</p></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PEUPLES -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <p class="text-[#E8B923] uppercase tracking-widest text-xs font-semibold mb-3">Identité culturelle</p>
      <h2 class="text-4xl font-bold mb-10">Peuples &amp; Traditions de Goulmou</h2>
      <div class="grid md:grid-cols-3 gap-8">

        <div class="bg-[#F5F0E8] rounded-2xl overflow-hidden shadow info-card">
          <img src="data:image/jpeg;base64," alt="Femmes Gourmantché — danse traditionnelle" class="people-img">
          <div class="p-5">
            <h3 class="font-bold text-xl mb-2">Gourmantché</h3>
            <p class="text-gray-600 text-sm">Maîtres de l'Est. Langue Gourmanchéma. Excellents agriculteurs, éleveurs et commerçants. Hospitalité légendaire — l'étranger est roi chez les Gourmantché. Tradition orale très riche.</p>
            <p class="text-xs font-semibold text-[#E8B923] mt-3">📍 Fada, Diapaga, Bogandé, Pama</p>
          </div>
        </div>

        <div class="bg-[#F5F0E8] rounded-2xl overflow-hidden shadow info-card">
          <img src="data:image/jpeg;base64," alt="Femmes Peul Fulani — culture pastorale" class="people-img">
          <div class="p-5">
            <h3 class="font-bold text-xl mb-2">Peul (Fulani)</h3>
            <p class="text-gray-600 text-sm">Éleveurs nomades très présents dans la région. Grands troupeaux de bovins traversant la savane. Culture pastorale vivante — danses, poésie, artisanat du cuir et des bijoux.</p>
            <p class="text-xs font-semibold text-[#E8B923] mt-3">📍 Zones rurales et périphériques</p>
          </div>
        </div>

        <div class="bg-[#F5F0E8] rounded-2xl overflow-hidden shadow info-card">
          <img src="data:image/jpeg;base64," alt="Mossi de l'Est — village traditionnel" class="people-img">
          <div class="p-5">
            <h3 class="font-bold text-xl mb-2">Mossi de l'Est</h3>
            <p class="text-gray-600 text-sm">Migrants venus du Plateau Central depuis plusieurs générations. Agriculteurs dynamiques intégrés dans la société Gourmantché. Brassage culturel enrichissant.</p>
            <p class="text-xs font-semibold text-[#E8B923] mt-3">📍 Fada et zones agricoles</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- BARRAGE DE KOMPIENGA -->
  <section class="py-20" style="background:linear-gradient(135deg,#E8B923,#c99a00);">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12 items-center text-gray-800">
        <div>
          <p class="text-[#008751] uppercase tracking-widest text-xs font-semibold mb-3">Énergie nationale</p>
          <h2 class="text-4xl font-bold mb-6">Le Barrage de Kompienga — Poumon Énergétique</h2>
          <p class="leading-relaxed mb-5 opacity-90">Le <strong>barrage hydroélectrique de Kompienga</strong>, situé dans la province de Kompienga, est l'un des plus grands ouvrages hydrauliques du Burkina Faso. D'une puissance de <strong>14 mégawatts</strong>, il contribue significativement à l'approvisionnement électrique national.</p>
          <p class="leading-relaxed mb-5 opacity-90">Le lac artificiel créé s'étend sur plusieurs milliers d'hectares, offrant un potentiel de <strong>pêche artisanale</strong> et de <strong>maraîchage</strong> important pour les populations riveraines. Les périmètres irrigués autour du lac produisent riz, légumes et fruits.</p>
          <p class="leading-relaxed opacity-90">Le site offre également des possibilités de <strong>tourisme lacustre</strong> — promenades en pirogue, observation des oiseaux aquatiques, pêche sportive dans un cadre naturel préservé.</p>
        </div>
        <div class="space-y-4">
          <div class="rounded-2xl overflow-hidden shadow-xl">
            <img src="data:image/jpeg;base64," alt="Lac de Kompienga — pêcheur en pirogue" style="width:100%;height:280px;object-fit:cover;display:block;">
          </div>
          <div class="bg-white/80 backdrop-blur rounded-2xl p-5">
            <h3 class="font-bold text-lg mb-3 text-gray-800">⚡ Caractéristiques du barrage</h3>
            <div class="space-y-2 text-sm">
              <div class="border-l-4 border-[#008751] pl-3"><p class="font-bold">Puissance installée</p><p class="text-gray-600">14 mégawatts — production hydroélectrique</p></div>
              <div class="border-l-4 border-[#008751] pl-3"><p class="font-bold">Surface du lac</p><p class="text-gray-600">~22 000 hectares</p></div>
              <div class="border-l-4 border-[#008751] pl-3"><p class="font-bold">Mise en service</p><p class="text-gray-600">1988 — barrage historique du Burkina</p></div>
              <div class="border-l-4 border-[#008751] pl-3"><p class="font-bold">Usages multiples</p><p class="text-gray-600">Électricité + irrigation + pêche + tourisme</p></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- POTENTIELS -->
  <section class="py-20 bg-[#F5F0E8]">
    <div class="max-w-7xl mx-auto px-6">
      <p class="text-[#E8B923] uppercase tracking-widest text-xs font-semibold mb-3">Économie &amp; Ressources</p>
      <h2 class="text-4xl font-bold mb-10">Potentiels de la Région</h2>
      <div class="grid md:grid-cols-2 gap-10">
        <div class="space-y-5">
          <div><div class="flex justify-between mb-2 text-sm font-semibold"><span>🐄 Élevage — Marché de bétail</span><span class="text-[#E8B923]">90%</span></div><div class="prog-bar"><div class="prog-fill" data-w="90"></div></div><p class="text-xs text-gray-400 mt-1">Grand marché de bétail de Fada — bovins, ovins, caprins</p></div>
          <div><div class="flex justify-between mb-2 text-sm font-semibold"><span>🌾 Agriculture — Coton &amp; Céréales</span><span class="text-[#E8B923]">80%</span></div><div class="prog-bar"><div class="prog-fill" data-w="80"></div></div><p class="text-xs text-gray-400 mt-1">Coton, mil, sorgho, maïs — région très productive</p></div>
          <div><div class="flex justify-between mb-2 text-sm font-semibold"><span>⚡ Hydroélectricité — Kompienga</span><span class="text-[#E8B923]">75%</span></div><div class="prog-bar"><div class="prog-fill" data-w="75"></div></div><p class="text-xs text-gray-400 mt-1">14 MW — alimentation électrique nationale</p></div>
          <div><div class="flex justify-between mb-2 text-sm font-semibold"><span>🥇 Mines — Or artisanal</span><span class="text-[#E8B923]">70%</span></div><div class="prog-bar"><div class="prog-fill" data-w="70"></div></div><p class="text-xs text-gray-400 mt-1">Orpaillage artisanal — gisements dans plusieurs zones</p></div>
          <div><div class="flex justify-between mb-2 text-sm font-semibold"><span>🐟 Pêche — Lac de Kompienga</span><span class="text-[#E8B923]">65%</span></div><div class="prog-bar"><div class="prog-fill" data-w="65"></div></div><p class="text-xs text-gray-400 mt-1">Tilapia, capitaine — approvisionnement régional</p></div>
          <div><div class="flex justify-between mb-2 text-sm font-semibold"><span>🏞️ Tourisme — Parcs &amp; Nature</span><span class="text-[#E8B923]">60%</span></div><div class="prog-bar"><div class="prog-fill" data-w="60"></div></div><p class="text-xs text-gray-400 mt-1">Accès aux parcs Arly et W — écotourisme en développement</p></div>
        </div>
        <div class="space-y-6">
          <div class="rounded-2xl p-6 text-gray-800" style="background:#E8B923">
            <h3 class="font-bold text-xl mb-4">🏆 Atouts de Goulmou</h3>
            <ul class="space-y-3 text-sm">
              <li class="flex gap-2"><span>✅</span> Barrage de Kompienga — énergie hydroélectrique</li>
              <li class="flex gap-2"><span>✅</span> Grand marché de bétail de Fada — commerce régional</li>
              <li class="flex gap-2"><span>✅</span> Accès aux Parcs Arly et W — tourisme international</li>
              <li class="flex gap-2"><span>✅</span> Zone cotonnière productive — Sofitex présente</li>
              <li class="flex gap-2"><span>✅</span> Or artisanal — zones d'orpaillage actives</li>
              <li class="flex gap-2"><span>✅</span> Route nationale 4 — axe commercial vers le Togo</li>
            </ul>
          </div>
          <div class="bg-white rounded-2xl p-6 shadow info-card">
            <h3 class="font-bold text-lg mb-3">🌿 La Mine de Youga</h3>
            <p class="text-gray-600 text-sm">La mine d'or industrielle de Youga, dans la province de Boulgou (région Goulmou), est l'une des mines d'or actives du Burkina Faso. Elle contribue aux exportations nationales d'or et à l'emploi local.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SITES & ATTRACTIONS -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <p class="text-[#E8B923] uppercase tracking-widest text-xs font-semibold mb-3">À visiter</p>
      <h2 class="text-4xl font-bold mb-10">Sites &amp; Attractions de Goulmou</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

        <div class="bg-[#F5F0E8] rounded-2xl overflow-hidden shadow info-card">
          <img src="data:image/jpeg;base64," alt="Lac de Kompienga" class="site-img">
          <div class="p-5">
            <h3 class="font-bold text-xl mb-2">Lac de Kompienga</h3>
            <p class="text-gray-600 text-sm">Grand lac artificiel. Promenades en pirogue, pêche sportive, observation des oiseaux aquatiques. Couchers de soleil spectaculaires sur l'eau. Site touristique en développement.</p>
          </div>
        </div>

        <div class="bg-[#F5F0E8] rounded-2xl overflow-hidden shadow info-card">
          <img src="data:image/jpeg;base64," alt="Parc National d'Arly — paysage" class="site-img">
          <div class="p-5">
            <h3 class="font-bold text-xl mb-2">Accès au Parc d'Arly</h3>
            <p class="text-gray-600 text-sm">Fada est la porte d'entrée vers le Parc National d'Arly. Éléphants, lions, buffles, hippos — safari accessible depuis la ville. Complexe W-Arly-Pendjari classé UNESCO.</p>
          </div>
        </div>

        <div class="bg-[#F5F0E8] rounded-2xl overflow-hidden shadow info-card">
          <img src="data:image/jpeg;base64," alt="Marché de bétail de Fada" class="site-img">
          <div class="p-5">
            <h3 class="font-bold text-xl mb-2">Marché de bétail de Fada</h3>
            <p class="text-gray-600 text-sm">Un des plus grands marchés de bétail du Burkina. Bovins, ovins, caprins amenés de toute la région et des pays voisins. Spectacle authentique d'une économie pastorale vivante.</p>
          </div>
        </div>

        <div class="bg-[#F5F0E8] rounded-2xl overflow-hidden shadow info-card">
          <img src="data:image/jpeg;base64," alt="Palais royal Gourmantché — Fada" class="site-img">
          <div class="p-5">
            <h3 class="font-bold text-xl mb-2">Palais royal Gourmantché</h3>
            <p class="text-gray-600 text-sm">Résidence du chef traditionnel de Fada. Architecture typique en banco. Gardien des traditions Gourmantché — cérémonies d'intronisation et de cour royale encore pratiquées.</p>
          </div>
        </div>

        <div class="bg-[#F5F0E8] rounded-2xl overflow-hidden shadow info-card">
          <img src="data:image/jpeg;base64," alt="Grand Marché de Fada" class="site-img">
          <div class="p-5">
            <h3 class="font-bold text-xl mb-2">Grand Marché de Fada</h3>
            <p class="text-gray-600 text-sm">Marché très animé et coloré. Céréales, légumes, artisanat Gourmantché, tissus, bijoux Peul. Brassage de toutes les ethnies de l'Est dans une ambiance chaleureuse.</p>
          </div>
        </div>

        <div class="bg-[#F5F0E8] rounded-2xl overflow-hidden shadow info-card">
          <img src="data:image/jpeg;base64," alt="Savane de l'Est — Goulmou" class="site-img">
          <div class="p-5">
            <h3 class="font-bold text-xl mb-2">Savane de l'Est</h3>
            <p class="text-gray-600 text-sm">Paysages de savane arborée à perte de vue. Baobabs centenaires, karités, fromagers. Randonnées et découverte de la faune locale — oiseaux, antilopes, phacochères.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CITATION -->
  <section class="py-16" style="background:linear-gradient(135deg,#E8B923,#c99a00);">
    <div class="max-w-4xl mx-auto px-6 text-center text-gray-800">
      <p class="text-3xl font-bold leading-relaxed mb-4" style="font-family:'Playfair Display',serif">
        « Chez les Gourmantché, l'étranger n'arrive jamais les mains vides — car on lui donne avant qu'il demande. »
      </p>
      <p class="text-[#008751] font-semibold">— Tradition d'hospitalité Gourmantché</p>
    </div>
  </section>

  <!-- NAVIGATION -->
  <section class="py-12 bg-[#F5F0E8]">
    <div class="max-w-7xl mx-auto px-6">
      <h3 class="text-2xl font-bold text-center mb-8">Découvrir les autres régions</h3>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="sourou.html"    class="bg-white px-5 py-3 rounded-xl shadow text-sm font-semibold transition" onmouseover="this.style.background='#A0522D';this.style.color='white'" onmouseout="this.style.background='white';this.style.color=''">← Sourou</a>
        <a href="sirba.html"     class="bg-white px-5 py-3 rounded-xl shadow text-sm font-semibold transition" onmouseover="this.style.background='#E8B923';this.style.color='white'" onmouseout="this.style.background='white';this.style.color=''">Sirba →</a>
        <a href="nakambe.html"   class="bg-white px-5 py-3 rounded-xl shadow text-sm font-semibold transition" onmouseover="this.style.background='#E8B923';this.style.color='white'" onmouseout="this.style.background='white';this.style.color=''">Nakambé →</a>
        <a href="tapoa.html"     class="bg-white px-5 py-3 rounded-xl shadow text-sm font-semibold transition" onmouseover="this.style.background='#E8B923';this.style.color='white'" onmouseout="this.style.background='white';this.style.color=''">Tapoa →</a>
        <a href="../regions.html" class="bg-[#008751] text-white px-5 py-3 rounded-xl shadow text-sm font-semibold hover:bg-[#006840] transition">← Toutes les régions</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-[#111827] text-white py-10 text-center">
    <p class="font-bold mb-1" style="font-family:'Playfair Display',serif">Burkina Terres d'Avenir</p>
    <p class="text-gray-400 text-sm">Projet L3 Informatique 2025-2026 — 🇧🇫 La Terre des Hommes Intègres</p>
  </footer>

  <script>
    window.addEventListener('load', () => {
      document.querySelectorAll('.prog-fill').forEach(bar => {
        const w = bar.getAttribute('data-w');
        if (w) setTimeout(() => { bar.style.width = w + '%'; }, 400);
      });
    });
  </script>
</body>
</html>